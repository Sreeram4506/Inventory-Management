generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Dealership {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  address     String?
  phone       String?
  email       String?
  logoBase64  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Relations
  users               User[]
  vehicles            Vehicle[]
  sales               Sale[]
  purchases           Purchase[]
  repairs             Repair[]
  customerNotes       CustomerNote[]
  advertisingExpenses AdvertisingExpense[]
  businessExpenses    BusinessExpense[]
  documents           DocumentRegistry[]
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  password  String
  name      String
  role      String   @default("STAFF") // ADMIN, MANAGER, STAFF
  createdAt DateTime @default(now())
  
  // Multi-tenancy
  dealershipId String     @db.ObjectId
  dealership   Dealership @relation(fields: [dealershipId], references: [id])

  // Relations for tracking activity
  vehiclesAdded Vehicle[]
  salesMade     Sale[]

  @@unique([email, dealershipId])
}

model Vehicle {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  vin               String
  make              String
  model             String
  year              Int
  mileage           Int
  color             String
  purchaseDate      DateTime
  status            String   @default("Available")
  titleNumber       String?
  daysInInventory   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Multi-tenancy
  dealershipId String     @db.ObjectId
  dealership   Dealership @relation(fields: [dealershipId], references: [id])

  // Relations
  purchase          Purchase?
  repairs           Repair[]
  sale              Sale?
  
  // Activity tracking
  createdById       String?  @db.ObjectId
  createdBy         User?    @relation(fields: [createdById], references: [id])
  customerNotes     CustomerNote[]

  // Indexes for common query patterns
  @@unique([vin, dealershipId])
  @@index([status])           // Dashboard filters by status
  @@index([createdAt])        // Sorted listing by creation date
  @@index([dealershipId])
}

model CustomerNote {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId    String   @db.ObjectId
  customerName String
  phone        String
  email        String?
  note         String
  createdAt    DateTime @default(now())

  // Multi-tenancy
  dealershipId String     @db.ObjectId
  dealership   Dealership @relation(fields: [dealershipId], references: [id])

  @@index([vehicleId])        // Lookup notes by vehicle
  @@index([dealershipId])
}


model Purchase {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId         String   @unique @db.ObjectId
  sellerName        String
  sellerAddress     String?
  sellerCity        String?
  sellerState       String?
  sellerZip         String?
  purchasePrice     Float
  buyerFee          Float    @default(0)
  transportCost     Float    @default(0)
  inspectionCost    Float    @default(0)
  registrationCost  Float    @default(0)
  totalPurchaseCost Float
  purchaseDate      DateTime
  paymentMethod     String
  documentBase64    String?
  sourceDocumentBase64 String?
  createdAt         DateTime @default(now())

  // Multi-tenancy
  dealershipId String     @db.ObjectId
  dealership   Dealership @relation(fields: [dealershipId], references: [id])

  @@index([dealershipId])
}

model Repair {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId       String   @db.ObjectId
  repairShop      String
  partsCost       Float
  laborCost       Float
  description     String?
  repairDate      DateTime @default(now())
  createdAt       DateTime @default(now())

  // Multi-tenancy
  dealershipId String     @db.ObjectId
  dealership   Dealership @relation(fields: [dealershipId], references: [id])

  @@index([vehicleId])        // Lookup repairs by vehicle
  @@index([dealershipId])
}

model Sale {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId      String   @unique @db.ObjectId
  customerName   String
  phone          String
  address        String
  driverLicense  String?
  saleDate       DateTime
  salePrice      Float
  paymentMethod  String
  profit         Float
  
  // Flattened Loan Details
  financeCompany String?
  downPayment   Float?
  loanAmount     Float?
  interestRate   Float?
  loanTerm       Int?
  monthlyPayment Float?

  // Activity tracking
  createdById    String?  @db.ObjectId
  createdBy      User?    @relation(fields: [createdById], references: [id])

  // Multi-tenancy
  dealershipId String     @db.ObjectId
  dealership   Dealership @relation(fields: [dealershipId], references: [id])

  // Document archiving
  billOfSaleBase64 String?
  hasBillOfSale    Boolean  @default(false)

  createdAt      DateTime @default(now())

  @@index([saleDate])         // Dashboard sorted by sale date
  @@index([createdById])      // Team analytics queries
  @@index([dealershipId])
}

model AdvertisingExpense {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  campaignName    String
  platform        String
  startDate       DateTime
  endDate         DateTime
  amountSpent     Float
  linkedVehicleId String?   @db.ObjectId
  createdAt       DateTime  @default(now())

  // Multi-tenancy
  dealershipId String     @db.ObjectId
  dealership   Dealership @relation(fields: [dealershipId], references: [id])

  @@index([dealershipId])
}

model BusinessExpense {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  category String
  amount   Float
  date     DateTime
  notes    String?
  createdAt DateTime @default(now())

  // Multi-tenancy
  dealershipId String     @db.ObjectId
  dealership   Dealership @relation(fields: [dealershipId], references: [id])

  @@index([dealershipId])
}

model DocumentRegistry {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  vin               String?
  make              String?
  model             String?
  year              String?
  color             String?
  mileage           String?
  titleNumber       String?
  purchaseDate      String?
  purchasedFrom     String?  // The dealer/source name
  sellerAddress     String?
  sellerCity        String?
  sellerState       String?
  sellerZip         String?
  documentType      String   @default("Used Vehicle Record")
  documentBase64    String
  sourceFileName    String?
  sourceDocumentBase64 String?
  
  // Disposition details (from Bill of Sale)
  disposedTo        String?
  disposedAddress   String?
  disposedCity      String?
  disposedState     String?
  disposedZip       String?
  disposedDate      String?
  disposedPrice     String?
  disposedOdometer  String?
  disposedDlNumber  String?
  disposedDlState   String?

  // Multi-tenancy
  dealershipId String     @db.ObjectId
  dealership   Dealership @relation(fields: [dealershipId], references: [id])

  createdAt         DateTime @default(now())

  @@index([vin])              // VIN lookup for document searches
  @@index([dealershipId])
}
